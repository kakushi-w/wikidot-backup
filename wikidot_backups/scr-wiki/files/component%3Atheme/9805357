  top: 100%;
  left: 50%;
  margin-left: -5px;
  border-width: 5px;
  border-style: solid;
  border-color: #2476db transparent transparent transparent;
}

.tooltipblue .tooltiptextblue {
  opacity: 0;
  transition: all 0.2s ease-in-out;
}

.tooltipblue:hover .tooltiptextblue {
  opacity: 1;
}

