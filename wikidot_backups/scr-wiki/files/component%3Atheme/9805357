  color: #fff;
  text-align: center;
  padding: 5px 0;
  border-radius: 6px;
   width: 120px;
  bottom: 100%;
  left: 50%;
  margin-left: -60px;
  position: absolute;
  z-index: 1;
}

.tooltipblue:hover .tooltiptextblue {
  visibility: visible;
}

.tooltipblue .tooltiptextblue::after {
  content: " ";
